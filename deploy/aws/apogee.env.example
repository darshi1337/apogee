APOGEE_HOST=127.0.0.1
APOGEE_PORT=8000
APOGEE_API_KEY=replace-with-a-long-random-token
APOGEE_ALLOW_LOCAL_PDFS=0
APOGEE_OLLAMA_HEALTH_TIMEOUT=3

# Keep the default for unpacked browser extensions. If you later front Apogee
# from a web app origin, replace this with a stricter expression for that app.
APOGEE_CORS_ORIGIN_REGEX=^(chrome-extension://.*|moz-extension://.*|https://your-domain.example)$
